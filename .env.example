# Contact form (optional — email sending requires Resend)
CONTACT_EMAIL=hello@shape-d.com
NEXT_PUBLIC_CONTACT_EMAIL=hello@shape-d.com
RESEND_API_KEY=
# onboarding@resend.dev is Resend's shared test sender (dev-only placeholder).
# In production, set this to a verified address on the shape-d.com domain
# (e.g. hello@shape-d.com) once Resend domain verification is complete (see #69).
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=shape-d-hp

# Rate limit shared store (optional — falls back to in-memory when unset)
# Upstash Redis:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Vercel KV (alternative):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# IP header trust for rate limiting (optional)
# Vercel sets VERCEL=1 automatically; forwarded headers are trusted on Vercel.
# Set to true when behind another trusted reverse proxy; false to ignore x-forwarded-for spoofing.
# CONTACT_TRUST_PROXY_IP_HEADERS=true
# Set to true only when traffic passes through Cloudflare (prevents cf-connecting-ip spoofing).
# CONTACT_TRUST_CLOUDFLARE_IP=true
